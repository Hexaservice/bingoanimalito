    "backfill:operational-claims": "node scripts/backfillOperationalClaims.js",
    "backfill:alias-lower": "node scripts/backfillAliasLower.js",
    "test:coverage": "jest --coverage",
    "reconciliar-premios": "node scripts/reconciliarPremiosPendientes.js",
